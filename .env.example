NEXT_PUBLIC_FORMSPREE_URL=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GA_ID=

# Cloudflare Pages: Settings → Variables (Production + Preview). Redeploy after edits.

# --- CV analytics (first match wins): D1 → KV → Upstash | dev: CV_ANALYTICS_MEMORY ---

# Shared for Cloudflare D1 + KV REST APIs
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Cloudflare D1 — use the database UUID (not the display name). Workers & Pages → D1 → your DB → copy ID.
# API token must include Account → D1 → Edit (or use a custom token with d1:edit).
CLOUDFLARE_D1_DATABASE_ID=a1b79376-6b1a-436e-ac47-88eca47e565f

# Cloudflare KV (optional; ignored if D1 is configured)
CLOUDFLARE_KV_NAMESPACE_ID=

# Upstash Redis (optional if D1 or KV above)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional (npm run dev only): in-memory stats, no Upstash. Resets on server restart.
# CV_ANALYTICS_MEMORY=1

# /admin — both required (non-empty). Restart dev after editing .env.local
ADMIN_PASSWORD=
# e.g. openssl rand -hex 32
ADMIN_SESSION_SECRET=
