NEXT_PUBLIC_FORMSPREE_URL=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GA_ID=

# Cloudflare Pages: Settings → Variables (Production + Preview). Redeploy after edits.

# --- CV analytics: Cloudflare D1 only (REST API) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Database UUID from Workers & Pages → D1 (not the display name). Token needs Account → D1 → Edit.
CLOUDFLARE_D1_DATABASE_ID=

# Optional (npm run dev only): in-memory stats, no D1. Resets when the dev server restarts.
# CV_ANALYTICS_MEMORY=1

# /admin — both required (non-empty). Restart dev after editing .env.local
ADMIN_PASSWORD=
# e.g. openssl rand -hex 32
ADMIN_SESSION_SECRET=
